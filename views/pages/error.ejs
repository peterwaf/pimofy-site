<a class="skip-link" href="#main">Skip to content</a>

<!-- Header / Navigation -->
<%- include('../partials/header') %>

<main id="main">
<section class="hero" style="padding: 80px 0; text-align: center;">
  <div class="container" style="max-width: 600px;">
    <div style="font-size: 4rem; font-weight: 800; color: var(--orange); margin-bottom: 20px;"><%= status || 500 %></div>
    <h1><%= title %></h1>
    <p class="lead"><%= description %></p>
    
    <% if (locals.error && locals.error.message) { %>
      <div style="background: #ffe6df; border: 1px solid #ff5a1f; padding: 16px; border-radius: 8px; margin: 20px 0; text-align: left;">
        <p><strong>Error Details:</strong></p>
        <p style="font-family: monospace; font-size: 0.9rem; color: var(--ink);"><%= error.message %></p>
      </div>
    <% } %>

    <div style="margin-top: 30px;">
      <a href="/" class="btn btn--primary">Go to Home</a>
      <a href="/blog" class="btn btn--ghost">Browse Blog</a>
    </div>
  </div>
</section>
</main>

<!-- Footer -->
<%- include('../partials/footer') %>

<script src="/js/script.js" defer></script>
