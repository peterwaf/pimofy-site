<a class="skip-link" href="#main">Skip to content</a>

<!-- Header / Navigation -->
<%- include('../partials/header') %>

<main id="main">
<section class="hero" style="padding: 60px 0;">
  <div class="container text-center reveal" style="max-width:500px;">
    <h1>Admin Login</h1>
    <p class="lead">Access the Pimofy Digital admin dashboard</p>
  </div>
</section>

<section class="section" style="padding: 40px 0;">
  <div class="container" style="max-width: 500px;">
    <div class="card reveal">
      <% if (locals.errors && errors.length) { %>
        <div style="background: #ffe6df; border: 1px solid #ff5a1f; color: #d63b14; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
          <strong>Login Failed:</strong>
          <ul style="margin: 8px 0 0 20px;">
            <% errors.forEach(err => { %>
              <li><%= err.message %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form method="POST" action="/auth/login" class="form">
        <div class="field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required autofocus />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>

        <button type="submit" class="btn btn--primary btn--lg" style="width: 100%; margin-top: 20px;">Sign In</button>
      </form>

      <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--line); text-align: center;">
        <p style="color: var(--muted); font-size: 0.9rem;">
          Contact <a href="mailto:hello@pimofydigital.com">hello@pimofydigital.com</a> if you need login assistance.
        </p>
      </div>
    </div>
  </div>
</section>
</main>

<!-- Footer -->
<%- include('../partials/footer') %>

<script src="/js/script.js" defer></script>
