<a class="skip-link" href="#main">Skip to content</a>

<%- include('../partials/header') %>

<main id="main">
  <section class="section" style="padding-top: 36px;">
    <div class="container" style="max-width: 900px;">
      <h1><%= isNew ? 'Create Article' : 'Edit Article' %></h1>
      <p style="color: var(--muted); margin-bottom: 20px;">Manage content and SEO metadata.</p>

      <% if (locals.errors && errors.length) { %>
        <div class="form__error" style="background: #ffe6df; border: 1px solid #ff5a1f; color: #d63b14; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px;">
          <strong>Please fix the following:</strong>
          <ul style="margin: 8px 0 0 20px;">
            <% errors.forEach((err) => { %>
              <li><%= err.message %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form method="POST" action="<%= isNew ? '/admin/articles' : '/admin/articles/' + article.id %>" class="form" style="gap: 14px;">
        <div class="field">
          <label for="title">Title</label>
          <input id="title" name="title" type="text" required value="<%= article ? article.title : '' %>" />
        </div>

        <div class="field">
          <label for="slug">Slug</label>
          <input id="slug" name="slug" type="text" required value="<%= article ? article.slug : '' %>" />
        </div>

        <div class="field">
          <label for="excerpt">Excerpt</label>
          <textarea id="excerpt" name="excerpt" required><%= article ? article.excerpt : '' %></textarea>
        </div>

        <div class="field">
          <label for="content">Content (HTML allowed)</label>
          <textarea id="content" name="content" rows="14" required><%= article ? article.content : '' %></textarea>
        </div>

        <div class="grid grid--2" style="gap: 14px;">
          <div class="field">
            <label for="category">Category</label>
            <input id="category" name="category" type="text" value="<%= article ? article.category : '' %>" />
          </div>
          <div class="field">
            <label for="tags">Tags (comma separated)</label>
            <input id="tags" name="tags" type="text" value="<%= article && article.tags ? article.tags.join(', ') : '' %>" />
          </div>
        </div>

        <div class="grid grid--2" style="gap: 14px;">
          <div class="field">
            <label for="seoTitle">SEO Title</label>
            <input id="seoTitle" name="seoTitle" type="text" value="<%= article ? article.seoTitle : '' %>" />
          </div>
          <div class="field">
            <label for="keywords">Keywords</label>
            <input id="keywords" name="keywords" type="text" value="<%= article ? article.keywords : '' %>" />
          </div>
        </div>

        <div class="field">
          <label for="metaDescription">Meta Description</label>
          <textarea id="metaDescription" name="metaDescription"><%= article ? article.metaDescription : '' %></textarea>
        </div>

        <div class="field" style="display: flex; align-items: center; gap: 10px;">
          <input id="published" name="published" type="checkbox" <%= article && article.published ? 'checked' : '' %> />
          <label for="published" style="margin: 0;">Publish now</label>
        </div>

        <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px;">
          <button type="submit" class="btn btn--primary"><%= isNew ? 'Create Article' : 'Save Changes' %></button>
          <a href="/admin/articles" class="btn btn--ghost">Cancel</a>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>

<script src="/js/script.js" defer></script>
