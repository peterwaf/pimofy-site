{
  "name": "pimofy-site",
  "version": "1.0.0",
  "description": "Pimofy Digital - Data Operations for SaaS & Ecommerce",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:drop && sequelize-cli db:create && sequelize-cli db:migrate && sequelize-cli db:seed:all"
  },
  "keywords": [
    "data-operations",
    "bpo",
    "saas",
    "ecommerce"
  ],
  "author": "Pimofy Digital",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "connect-session-sequelize": "^7.1.7",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "postgres": "^3.4.9",
    "sanitize-html": "^2.17.5",
    "sequelize": "^6.35.0",
    "sequelize-cli": "^6.6.0",
    "vercel": "^54.18.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
