<a class="skip-link" href="#main">Skip to content</a>

<!-- Header / Navigation -->
<%- include('../partials/header') %>

<main id="main">
<article>
  <!-- ARTICLE HERO -->
  <section class="section article-hero">
    <div class="container" style="max-width:820px;">
      <span class="tag"><%= post.category %></span>
      <h1><%= post.title %></h1>
      <p class="article-meta">
        By <%= post.author.name %> · <%= new Date(post.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %> · <%= readingTime %> min read
      </p>
    </div>
  </section>

  <div class="container" style="max-width:900px;">
    <img class="article-hero__img" src="<%= post.featuredImage %>" alt="<%= post.title %>" width="1024" height="576" />
  </div>

  <!-- ARTICLE BODY -->
  <section class="section" style="padding-top:40px;">
    <div class="container article-body" style="max-width:820px;">
      <%- post.content %>
    </div>
  </section>

  <!-- ARTICLE META -->
  <section class="section" style="padding: 40px 0;">
    <div class="container" style="max-width:820px;">
      <div style="border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 20px 0;">
        <p style="color: var(--muted); margin-bottom: 10px;"><strong>Tags:</strong></p>
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          <% if (post.tags && post.tags.length) { %>
            <% post.tags.forEach(tag => { %>
              <a href="/blog/tag/<%= tag %>" style="display: inline-block; background: var(--purple-light); color: var(--purple); padding: 6px 12px; border-radius: 20px; font-size: 0.9rem; text-decoration: none;">
                <%= tag %>
              </a>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED ARTICLES -->
  <% if (related && related.length > 0) { %>
    <section class="section section--soft">
      <div class="container">
        <h2 style="margin-bottom: 32px;">Related Articles</h2>
        <div class="grid grid--3">
          <% related.forEach((relPost, index) => { %>
            <a class="card article reveal" <% if (index > 0) { %>data-delay="<%= Math.min(index, 2) %>"<% } %> href="/blog/<%= relPost.slug %>">
              <div class="article__thumb">
                <img class="article__img" src="<%= relPost.featuredImage %>" alt="<%= relPost.title %>" width="1024" height="576" />
                <span class="tag tag--overlay"><%= relPost.category %></span>
              </div>
              <div class="article__body">
                <h3><%= relPost.title %></h3>
                <p><%= relPost.excerpt %></p>
                <span class="link">Read more →</span>
              </div>
            </a>
          <% }); %>
        </div>
      </div>
    </section>
  <% } %>

  <!-- CTA -->
  <section class="section cta-band">
    <div class="container cta-band__grid reveal">
      <div class="cta-band__text">
        <h2>
          <span class="cta-band__bookicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
          Find Your Real Constraint
        </h2>
        <p>Book a free Operations Capacity Audit™ and we'll show you exactly where your team's time is going.</p>
      </div>
      <div class="cta-band__action">
        <a href="/contact" class="btn btn--white btn--lg">Book Your Free Capacity Audit™</a>
      </div>
    </div>
  </section>
</article>
</main>

<!-- Footer -->
<%- include('../partials/footer') %>

<script src="/js/script.js" defer></script>
