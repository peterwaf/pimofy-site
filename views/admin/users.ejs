<div class="admin-page">
  <section>
    <div>
      <div class="layout-row-between pagination-row">
        <div>
          <h1>Manage Users</h1>
          <p class="cell-muted">Create and control admin access.</p>
        </div>
        <a href="/admin/users/new" class="btn btn--primary">New User</a>
      </div>

      <div class="card table-wrap">
        <table class="table-clean">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!users || users.length === 0) { %>
              <tr>
                <td colspan="5" class="cell-muted">No users found.</td>
              </tr>
            <% } %>
            <% (users || []).forEach((u) => { %>
              <tr>
                <td><strong><%= u.name %></strong></td>
                <td><%= u.email %></td>
                <td><span class="tag"><%= u.role %></span></td>
                <td>
                  <% if (u.active) { %>
                    <span class="tag tag--active">Active</span>
                  <% } else { %>
                    <span class="tag tag--disabled">Disabled</span>
                  <% } %>
                </td>
                <td>
                  <% if (u.active) { %>
                    <form method="POST" action="/admin/users/<%= u.id %>/disable" onsubmit="return confirm('Disable this user?');">
                      <button type="submit" class="btn btn--ghost">Disable</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</div>
