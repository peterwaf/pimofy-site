<main id="main">
<section class="section section--compact">
  <div class="container max-w-500" style="padding-top: 32px; padding-bottom: 32px;">
    <div style="display: flex; justify-content: center; align-items: center; padding: 8px 0 18px;">
      <img src="/assets/logo.png" alt="Pimofy Digital" width="180" height="48" style="display: block; max-width: 100%; height: auto;" />
    </div>

    <h1 style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;">Admin Login</h1>

    <div class="card">
      <% if (locals.errors && errors.length) { %>
        <div class="form__error show">
          <strong>Login Failed:</strong>
          <ul>
            <% errors.forEach(err => { %>
              <li><%= err.message %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form method="POST" action="/auth/login" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required autofocus />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>

        <button type="submit" class="btn btn--primary btn--lg login-submit">Sign In</button>
      </form>
    </div>
  </div>
</section>
</main>
