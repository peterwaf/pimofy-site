<a class="skip-link" href="#main">Skip to content</a>

<!-- Header / Navigation -->
<%- include('../partials/header') %>

<main id="main">
<section class="hero hero--compact">
  <div class="container text-center reveal max-w-500">
    <h1>Admin Login</h1>
    <p class="lead">Access the Pimofy Digital admin dashboard</p>
  </div>
</section>

<section class="section section--compact">
  <div class="container max-w-500">
    <div class="card reveal">
      <% if (locals.errors && errors.length) { %>
        <div class="form__error show">
          <strong>Login Failed:</strong>
          <ul>
            <% errors.forEach(err => { %>
              <li><%= err.message %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form method="POST" action="/auth/login" class="form">
        <div class="field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required autofocus />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>

        <button type="submit" class="btn btn--primary btn--lg login-submit">Sign In</button>
      </form>

      <div class="login-divider">
        <p class="cell-muted form__note">
          Contact <a href="mailto:hello@pimofydigital.com">hello@pimofydigital.com</a> if you need login assistance.
        </p>
      </div>
    </div>
  </div>
</section>
</main>

<!-- Footer -->
<%- include('../partials/footer') %>

<script src="/js/script.js" defer></script>
