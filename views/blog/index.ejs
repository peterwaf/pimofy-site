<a class="skip-link" href="#main">Skip to content</a>

<!-- Header / Navigation -->
<%- include('../partials/header') %>

<main id="main">
<!-- HERO -->
<section class="hero">
  <div class="container text-center reveal" style="max-width:780px;">
    <span class="eyebrow">Resources</span>
    <h1>Operations Insights & Resources</h1>
    <p class="lead">Practical thinking on data operations, capacity, and scaling without the overhead — for SaaS and Ecommerce leaders.</p>
  </div>
</section>

<!-- FEATURED -->
<section class="section section--soft">
  <div class="container reveal">
    <div class="callout" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:24px;text-align:left;">
      <div style="flex:1;min-width:260px;">
        <span class="tag">Featured</span>
        <h2 style="margin:6px 0 8px;">Free Operations Capacity Audit™</h2>
        <p style="margin:0;">Find out exactly where your team is losing time to repetitive data work — in under 30 minutes, at no cost.</p>
      </div>
      <a href="/contact" class="btn btn--primary btn--lg">Book Your Free Audit</a>
    </div>
  </div>
</section>

<!-- ARTICLES -->
<section class="section">
  <div class="container">
    <div class="section__head reveal"><h2>Articles & Insights</h2><p>Practical thinking on data operations, capacity, and scaling without the overhead.</p></div>
    
    <div class="grid grid--3">
      <% posts.forEach((post, index) => { %>
        <a class="card article reveal" <% if (index > 0) { %>data-delay="<%= Math.min(index, 2) %>"<% } %> href="/blog/<%= post.slug %>">
          <div class="article__thumb">
            <img class="article__img" src="<%= post.featuredImage %>" alt="<%= post.title %>" width="1024" height="576" />
            <span class="tag tag--overlay"><%= post.category %></span>
          </div>
          <div class="article__body">
            <h3><%= post.title %></h3>
            <p><%= post.excerpt %></p>
            <span class="link">Read more →</span>
          </div>
        </a>
      <% }); %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div style="display: flex; justify-content: center; gap: 10px; margin-top: 40px;">
        <% if (currentPage > 1) { %>
          <a href="/blog?page=1" class="btn btn--ghost">First</a>
          <a href="/blog?page=<%= currentPage - 1 %>" class="btn btn--ghost">Previous</a>
        <% } %>
        
        <span style="padding: 12px 16px; font-weight: 600;">Page <%= currentPage %> of <%= totalPages %></span>
        
        <% if (currentPage < totalPages) { %>
          <a href="/blog?page=<%= currentPage + 1 %>" class="btn btn--ghost">Next</a>
          <a href="/blog?page=<%= totalPages %>" class="btn btn--ghost">Last</a>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<!-- CTA -->
<section class="section cta-band">
  <div class="container cta-band__grid reveal">
    <div class="cta-band__text">
      <h2>
        <span class="cta-band__bookicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
        Want This Applied to Your Team?
      </h2>
      <p>Reading about capacity is useful. Seeing exactly where yours is leaking is better. Book a free Operations Capacity Audit™ and we'll map it for you.</p>
    </div>
    <div class="cta-band__action">
      <a href="/contact" class="btn btn--white btn--lg">Book Your Free Capacity Audit™</a>
    </div>
  </div>
</section>
</main>

<!-- Footer -->
<%- include('../partials/footer') %>

<script src="/js/script.js" defer></script>
