<div class="admin-page">
  <section>
    <div>
      <div class="admin-page__header">
        <h2>Content Library</h2>
        <p>Create, edit, publish, and remove blog content.</p>
      </div>

      <div class="layout-row-between pagination-row">
        <div class="actions-row">
          <a href="/admin/articles/import" class="btn btn--ghost">Import CSV</a>
          <a href="/admin/articles/new" class="btn btn--primary">New Article</a>
        </div>
      </div>

      <form method="GET" action="/admin/articles" class="card card--compact form pagination-row">
        <div class="grid grid--3">
          <div class="field">
            <label for="article-q">Search</label>
            <input id="article-q" type="text" name="q" value="<%= articleFilters && articleFilters.q ? articleFilters.q : '' %>" placeholder="Title, slug, or excerpt" />
          </div>
          <div class="field">
            <label for="article-category">Category</label>
            <select id="article-category" name="category">
              <option value="">All categories</option>
              <% (categoryOptions || []).forEach((categoryName) => { %>
                <option value="<%= categoryName %>" <%= articleFilters && articleFilters.category === categoryName ? 'selected' : '' %>><%= categoryName %></option>
              <% }); %>
            </select>
          </div>
          <div class="field">
            <label for="article-tag">Tag</label>
            <select id="article-tag" name="tag">
              <option value="">All tags</option>
              <% (tagOptions || []).forEach((tagName) => { %>
                <option value="<%= tagName %>" <%= articleFilters && articleFilters.tag === tagName ? 'selected' : '' %>><%= tagName %></option>
              <% }); %>
            </select>
          </div>
        </div>
        <div class="actions-row">
          <button type="submit" class="btn btn--primary">Apply Filters</button>
          <a href="/admin/articles" class="btn btn--ghost">Reset</a>
        </div>
      </form>

      <div class="card table-wrap">
        <table class="table-clean">
          <thead>
            <tr>
              <th>Title</th>
              <th>Category</th>
              <th>Tags</th>
              <th>Status</th>
              <th>Author</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!articles || articles.length === 0) { %>
              <tr>
                <td colspan="6" class="cell-muted">No articles found.</td>
              </tr>
            <% } %>
            <% (articles || []).forEach((article) => { %>
              <tr>
                <td>
                  <strong><%= article.title %></strong>
                  <div class="cell-muted">/<%= article.slug %></div>
                </td>
                <td><%= article.category || 'Uncategorized' %></td>
                <td>
                  <% if (article.tags && article.tags.length) { %>
                    <div class="tag-list">
                      <% article.tags.forEach((tagName) => { %>
                        <span class="tag tag--plain"><%= tagName %></span>
                      <% }); %>
                    </div>
                  <% } else { %>
                    <span class="cell-muted">-</span>
                  <% } %>
                </td>
                <td>
                  <% if (article.published) { %>
                    <span class="tag">Published</span>
                  <% } else { %>
                    <span class="tag tag--draft">Draft</span>
                  <% } %>
                </td>
                <td><%= article.author ? article.author.name : 'Unknown' %></td>
                <td class="table-actions">
                  <a href="/admin/articles/<%= article.id %>/edit" class="btn btn--ghost">Edit</a>
                  <form
                    method="POST"
                    action="/admin/articles/<%= article.id %>/delete"
                    data-confirm-delete
                    data-confirm-title="<%= article.title %>"
                  >
                    <button type="submit" class="btn btn--ghost">Delete</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <div class="actions-row actions-row--center pagination-row">
          <% if (prevPageUrl) { %>
            <a class="btn btn--ghost" href="<%= prevPageUrl %>">Previous</a>
          <% } %>
          <span class="btn btn--ghost pagination-pill">Page <%= currentPage %> of <%= totalPages %></span>
          <% if (nextPageUrl) { %>
            <a class="btn btn--ghost" href="<%= nextPageUrl %>">Next</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </section>
</div>
