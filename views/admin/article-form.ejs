<div class="admin-page">
  <section>
    <div>
      <div class="admin-page__header">
        <h2><%= isNew ? 'Create Article' : 'Edit Article' %></h2>
        <p>Manage the featured image, article structure, and SEO metadata.</p>
      </div>

      <div id="article-feedback-anchor" style="scroll-margin-top: 120px;"></div>
      <div class="form__feedback" aria-live="polite" tabindex="-1">
        <div class="form__success<% if (articleMessage) { %> show<% } %>"><%= articleMessage || '' %></div>
        <% if (locals.errors && errors.length) { %>
          <div class="form__error show">
            <strong>Please fix the following:</strong>
            <ul>
              <% errors.forEach((err) => { %>
                <li><%= err.message %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>
      </div>

      <% const resolvedCategoryOptions = Array.isArray(categoryOptions) && categoryOptions.length ? categoryOptions : ['Uncategorized']; %>
      <% const rawCategoryValue = formData.category || (article ? article.category : ''); %>
      <% const selectedCategory = rawCategoryValue && resolvedCategoryOptions.includes(rawCategoryValue) ? rawCategoryValue : 'Uncategorized'; %>
      <% const customCategoryValue = rawCategoryValue && !resolvedCategoryOptions.includes(rawCategoryValue) ? rawCategoryValue : ''; %>
      <% const resolvedTagOptions = Array.isArray(tagOptions) ? tagOptions : []; %>
      <% const selectedTags = Array.isArray(formData.tags)
        ? formData.tags
        : (typeof formData.tags === 'string' && formData.tags.trim()
          ? formData.tags.split(',').map((tag) => tag.trim()).filter(Boolean)
          : (article && Array.isArray(article.tags) ? article.tags : [])); %>

      <form method="POST" action="<%= isNew ? '/admin/articles' : '/admin/articles/' + article.id %>" enctype="multipart/form-data" class="form admin-form" style="gap: 14px;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="field">
          <label for="title">Title</label>
          <input id="title" name="title" type="text" required value="<%= formData.title || (article ? article.title : '') %>" />
        </div>

        <div class="field">
          <label for="slug">Slug</label>
          <input id="slug" name="slug" type="text" required value="<%= formData.slug || (article ? article.slug : '') %>" />
        </div>

        <div class="field">
          <label for="excerpt">Excerpt</label>
          <textarea id="excerpt" name="excerpt" required><%= formData.excerpt || (article ? article.excerpt : '') %></textarea>
        </div>

        <div class="field admin-featured-image">
          <label for="featuredImage">Featured image</label>
          <input id="featuredImage" data-featured-image-input name="featuredImage" type="file" accept="image/*" />
          <input type="hidden" name="existingFeaturedImage" value="<%= article && article.featuredImage ? article.featuredImage : '' %>" />
          <button type="button" class="admin-featured-image__preview" data-featured-image-preview data-media-preview-src="<%= formData.featuredImage || (article && article.featuredImage ? article.featuredImage : '') %>" data-media-preview-alt="Featured image preview">
            <% if (formData.featuredImage || (article && article.featuredImage)) { %>
              <img src="<%= formData.featuredImage || article.featuredImage %>" alt="Featured image preview" />
            <% } else { %>
              <span>No image selected yet.</span>
            <% } %>
          </button>
        </div>

        <div class="field">
          <label for="content">Content</label>
          <div class="rich-editor" data-rich-editor>
            <div class="rich-editor__toolbar" data-rich-editor-toolbar>
              <button type="button" data-command="formatBlock" data-value="p">P</button>
              <button type="button" data-command="formatBlock" data-value="h1">H1</button>
              <button type="button" data-command="formatBlock" data-value="h2">H2</button>
              <button type="button" data-command="formatBlock" data-value="h3">H3</button>
              <button type="button" data-command="formatBlock" data-value="h4">H4</button>
              <button type="button" data-command="formatBlock" data-value="h5">H5</button>
              <button type="button" data-command="formatBlock" data-value="h6">H6</button>
              <button type="button" data-command="bold"><strong>B</strong></button>
              <button type="button" data-command="italic"><em>I</em></button>
              <button type="button" data-command="underline"><u>U</u></button>
              <button type="button" data-command="insertUnorderedList">• List</button>
              <button type="button" data-command="createLink">Link</button>
              <button type="button" data-command="createLink" data-link-target="_blank">Link (New Tab)</button>
              <button type="button" data-command="editLink">Edit Link</button>
              <button type="button" data-command="unlink">Unlink</button>
            </div>
            <div id="content" class="rich-editor__surface" contenteditable="true" data-rich-editor-surface></div>
            <textarea name="content" class="rich-editor__source" data-rich-editor-source hidden required><%= formData.content || (article ? article.content : '') %></textarea>
          </div>
        </div>

        <div class="grid grid--2" style="gap: 14px;">
          <div class="field">
            <label for="categorySelect">Category</label>
            <select id="categorySelect" data-category-select>
              <% resolvedCategoryOptions.forEach((categoryName) => { %>
                <option value="<%= categoryName %>" <%= selectedCategory === categoryName ? 'selected' : '' %>><%= categoryName %></option>
              <% }); %>
              <option value="__custom__" <%= customCategoryValue ? 'selected' : '' %>>Add New Category</option>
            </select>
            <input id="category" name="category" type="hidden" value="<%= customCategoryValue || selectedCategory %>" data-category-hidden-input />
            <div style="display: grid; gap: 8px; margin-top: 8px;" data-category-custom-wrap <%= customCategoryValue ? '' : 'hidden' %>>
              <label for="categoryCustom" style="margin: 0; font-weight: 500; color: var(--muted);">New category name</label>
              <input id="categoryCustom" type="text" value="<%= customCategoryValue %>" placeholder="Enter a new category" data-category-custom-input />
            </div>
            <button type="button" class="btn btn--ghost" style="margin-top: 8px;" data-category-clear>Remove category (set to Uncategorized)</button>
          </div>
          <div class="field">
            <label for="tagInput">Tags</label>
            <input id="tags" name="tags" type="hidden" value="<%= selectedTags.join(', ') %>" data-tags-hidden-input />
            <div class="field" style="margin-bottom: 0;">
              <input id="tagInput" type="text" placeholder="Add a tag and press Enter" data-tag-custom-input />
            </div>
            <div style="display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap;">
              <button type="button" class="btn btn--ghost" data-tag-add-custom>Add Tag</button>
              <button type="button" class="btn btn--ghost" data-tag-clear>Clear Tags</button>
            </div>
            <div data-tag-list style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;"></div>
            <% if (resolvedTagOptions.length) { %>
              <p class="form__note" style="margin-top: 10px;">Quick add from existing tags:</p>
              <div data-tag-options style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;">
                <% resolvedTagOptions.forEach((tagName) => { %>
                  <button type="button" class="btn btn--ghost" data-tag-option="<%= tagName %>"><%= tagName %></button>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>

        <div class="grid grid--2" style="gap: 14px;">
          <div class="field">
            <label for="seoTitle">SEO Title</label>
            <input id="seoTitle" name="seoTitle" type="text" value="<%= formData.seoTitle || (article ? article.seoTitle : '') %>" />
            <p class="form__note">Aim for 50-60 characters and keep the primary keyword near the beginning.</p>
            <p class="form__note">Example: B2B Data Operations Audit Checklist for Growing Teams</p>
          </div>
          <div class="field">
            <label for="keywords">Keywords</label>
            <input id="keywords" name="keywords" type="text" value="<%= formData.keywords || (article ? article.keywords : '') %>" />
            <p class="form__note">Use 3-8 focused phrases separated by commas. Avoid broad or repeated terms.</p>
            <p class="form__note">Example: data operations audit, b2b seo strategy, analytics governance</p>
          </div>
        </div>

        <div class="field">
          <label for="metaDescription">Meta Description</label>
          <textarea id="metaDescription" name="metaDescription"><%= formData.metaDescription || (article ? article.metaDescription : '') %></textarea>
          <p class="form__note">Write a clear summary in 140-160 characters, include the primary keyword once, and add a strong action phrase.</p>
          <p class="form__note">Example: Improve campaign performance with this practical data operations audit guide built for B2B teams that need cleaner reporting and faster decisions.</p>
        </div>

        <div class="field" style="display: flex; align-items: center; gap: 10px;">
          <input id="published" name="published" type="checkbox" <%= formData.published === 'on' || (article && article.published) ? 'checked' : '' %> />
          <label for="published" style="margin: 0;">Publish now</label>
        </div>

        <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px;">
          <button type="submit" class="btn btn--primary"><%= isNew ? 'Create Article' : 'Save Changes' %></button>
          <a href="/admin/articles" class="btn btn--ghost">Cancel</a>
        </div>
      </form>
    </div>
  </section>
</div>
